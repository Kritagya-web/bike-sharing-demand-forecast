# Copy to .env and fill in. Never commit .env.
# Get keys from IAM (your user) or use AWS SSO / instance profile instead of long-lived keys when possible.

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

# S3: training data and SageMaker artifacts — same bucket is fine
BUCKET_NAME=your-bucket-name
SAGEMAKER_BUCKET=your-bucket-name
S3_TRAIN_PREFIX=data/hour.csv

# SageMaker execution role (training + hosting)
SAGEMAKER_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT_ID:role/YOUR_SageMakerExecutionRole

# Optional fixed training job name (otherwise auto: bike-demand-xgb-<UTC-timestamp>)
# SAGEMAKER_TRAINING_JOB_NAME=my-one-off-job

# After training (output from job or estimator.model_data)
# MODEL_DATA_S3=s3://your-bucket/.../output/model.tar.gz

# After deploy + daily email Lambda / SES (same region as endpoint)
# SAGEMAKER_ENDPOINT_NAME=your-endpoint-name
# Verified in SES; sandbox also verify REPORT_EMAIL_TO
# REPORT_EMAIL_FROM=reports@yourdomain.com
# REPORT_EMAIL_TO=your-inbox@example.com
# REPORT_TIMEZONE=America/New_York
